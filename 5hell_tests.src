globals.test_cmd_enum_pipe = function()
	command.enum("-p")
	command.enum(["alpha", "beta"])
	globals.PIPE_HITS = []
	res = command.enum("-d", "testsink @pipe")
	err = globals._assert_contains(res, "task complete")
	if err then
		return err
	end if
	err = globals._assert_eq(str(globals.PIPE_HITS.len), "2")
	if err then return err
	err = globals._assert_eq(globals.PIPE_HITS[0], "alpha")
	if err then return err
	err = globals._assert_eq(globals.PIPE_HITS[1], "beta")
	if err then return err
	command.enum("-p")
	return null
end function

globals.test_cmd_do_batch = function()
	batch = globals._suite_path("do_batch.bat")
	command.poke(batch,
		"testsink alpha"+char(10)+
		"testsink beta")
	globals.PIPE_HITS = []
	res = command.do("1", "-f", batch)
	err = globals._assert_contains(res, "batch complete")
	if err then return err
	err = globals._assert_eq(str(globals.PIPE_HITS.len), "2")
	if err then return err
	err = globals._assert_eq(globals.PIPE_HITS[0], "alpha")
	if err then return err
	err = globals._assert_eq(globals.PIPE_HITS[1], "beta")
	if err then return err
	return null
end function

