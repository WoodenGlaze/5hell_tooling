command.shell = function(arg1, arg2=0, arg3=0, arg4=0)
	cmd_text = ""
	if typeof(arg1) == "list" then
		for part in arg1
			if part == "|" then break
			if cmd_text == "" then
				cmd_text = part
			else
				cmd_text = cmd_text + " " + part
			end if
		end for
	else
		cmd_text = arg1
	end if
	if typeof(cmd_text) != "string" then return null
	cmd_text = cmd_text.trim
	if cmd_text == "" then return null
	if cmd_text.indexOf("||") != null then
		seq = cmd_text.split("||")
		last = null
		for step in seq
			step = step.trim
			if step == "" then continue
			last = command.shell(step)
		end for
		return last
	end if
	parts = cmd_text.split(" ")
	args = []
	for part in parts
		if part != "" then args.push(part)
	end for
	if not args.len then return null
	segments = []
	segment = []
	for part in args
		if part == "|" then
			if segment.len then segments.push(segment)
			segment = []
		else
			segment.push(part)
		end if
	end for
	if segment.len then segments.push(segment)
	if not segments.len then return null
	last = null
	for segment in segments
		if last != null then segment.push(last)
		if segment.len and segment[0] == "return" then
			if segment.len > 1 then return segment[1]
			return last
		end if
		cmd_name = segment[0]
		if not command.hasIndex(cmd_name) then return "shell: command not found: "+cmd_name
		runner = command[cmd_name]
		a1 = 0
		a2 = 0
		a3 = 0
		a4 = 0
		if segment.len > 1 then a1 = segment[1]
		if segment.len > 2 then a2 = segment[2]
		if segment.len > 3 then a3 = segment[3]
		if segment.len > 4 then a4 = segment[4]
		catch = runner(a1, a2, a3, a4)
		if typeof(catch) == "function" then catch = catch()
		last = catch
	end for
	return last
end function

globals._test_cases = []
globals._test_passes = 0
globals._test_fails = 0

globals._test_add = function(name, fn)
	globals._test_cases.push({"name":name, "fn":fn})
end function

globals._assert = function(cond, msg="assert failed")
	if cond then return null
	return msg
end function

globals._assert_eq = function(actual, expected, msg=0)
	if actual == expected then return null
	if not msg then msg = "expected ["+str(expected)+"] got ["+str(actual)+"]"
	return msg
end function

globals._assert_contains = function(haystack, needle, msg=0)
	if typeof(haystack) != "string" then return "expected string output"
	if haystack.indexOf(needle) == null then
		if not msg then msg = "expected to find ["+needle+"]"
		return msg
	end if
	return null
end function

globals._assert_file_exists = function(path, msg=0)
	if globals.get_file(path) then return null
	if not msg then msg = "missing file: "+path
	return msg
end function

globals._assert_file_missing = function(path, msg=0)
	if not globals.get_file(path) then return null
	if not msg then msg = "file still exists: "+path
	return msg
end function

