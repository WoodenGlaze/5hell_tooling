globals.test_cmd_enum_insert_remove = function()
	command.enum("-p")
	command.enum(["alpha", "gamma"])
	res = command.enum("-i", "1", "beta")
	err = globals._assert_contains(res, "inserted")
	if err then return err
	if command.enum("1") != "beta" then return "enum insert failed"
	res = command.enum("-r", "1")
	err = globals._assert_contains(res, "removed")
	if err then return err
	if command.enum("-l") != "2" then return "enum remove length mismatch"
	if command.enum("1") != "gamma" then return "enum remove failed"
	command.enum("-p")
	return null
end function

