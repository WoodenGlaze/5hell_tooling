	return globals._assert_eq(globals.CLIP["a"], "clip-test")
end function

globals.test_cmd_enum_list = function()
	command.enum("-p")
	res = command.enum(["one", "two"])
	if res != "enum: list enumerated" then return res
	if command.enum("-l") != "2" then return "enum length mismatch"
	if command.enum("1") != "two" then return "enum index mismatch"
	command.enum("-p")
	return globals._assert_eq(command.enum("-l"), "0")
end function

globals.test_fs_mkdir_cd_pwd = function()
	work = globals._suite_path("workspace")
	command.mkdir(work)
	if typeof(globals.get_file(work)) != "file" then return "mkdir failed"
	cd_err = command.cd(work)
	if cd_err then return cd_err
	err = globals._assert_eq(command.pwd(), work)
	command.cd(globals._test_root)
	return err
end function

globals.test_fs_poke_cat_append = function()
	file_path = globals._suite_path("alpha.txt")
	res = command.poke(file_path, "alpha")
	if typeof(res) != "file" then return "poke did not return file"
	if command.cat(file_path) != "alpha" then return "cat mismatch"
	command.append(file_path, "beta")
	c2 = command.cat(file_path)
	return globals._assert_contains(c2, "beta")
end function

globals.test_fs_copy_move_merge = function()
	src = globals._suite_path("copy_source.txt")
	dst = globals._suite_path("copy_target.txt")
	moved = globals._suite_path("moved_target.txt")
	command.poke(src, "alpha")
	command.cp(src, dst)
	err = globals._assert_file_exists(dst)
	if err then return err
	command.mv(dst, moved)
	err = globals._assert_file_exists(moved)
	if err then return err
	command.poke(globals._suite_path("merge_source.txt"), "beta")
	command.merge(src, globals._suite_path("merge_source.txt"))
	merged = command.cat(src)
	return globals._assert_contains(merged, "beta")
end function

globals.test_fs_ls = function()
	work_file = globals._suite_path("ls_probe.txt")
	work_dir = globals._suite_path("ls_probe_dir")
	command.poke(work_file, "probe")
	command.mkdir(work_dir)
	out = command.ls()
	if typeof(out) != "string" then return "ls did not return string"
	if out.indexOf("ls_probe.txt") == null then return "ls_probe.txt missing"
	if out.indexOf("ls_probe_dir") == null then return "ls_probe_dir missing"
	return null
end function

globals.test_fs_rm_cleanup = function()
	files = [
		globals._suite_path("alpha.txt"),
		globals._suite_path("copy_source.txt"),
		globals._suite_path("moved_target.txt"),
		globals._suite_path("merge_source.txt"),
		globals._suite_path("ls_probe.txt")
	]
	for path in files
		command.rm(path)
	end for
	command.rm("-r", globals._suite_path("ls_probe_dir"))
	command.rm("-r", globals._suite_path("workspace"))
	if globals.get_file(globals._suite_path("alpha.txt")) then return "alpha.txt still exists"
	if globals.get_file(globals._suite_path("ls_probe_dir")) then return "ls_probe_dir still exists"
	return null
end function

globals.test_fs_recursive_rm = function()
	root_dir = globals._suite_path("deep")
	inner_dir = root_dir + "/inner"
	deep_file = inner_dir + "/deep.txt"
	command.mkdir(root_dir)
	command.mkdir(inner_dir)
	command.poke(deep_file, "depth")
	if typeof(globals.get_file(deep_file)) != "file" then return "deep file missing"
	command.rm("-r", root_dir)
	if globals.get_file(root_dir) then return "root dir still exists"
	if globals.get_file(deep_file) then return "deep file still exists"
	return null
end function

