globals.test_cmd_rnip = function()
	res = command.rnip("3")
	ips = res.trim.split(char(10))
	if ips.len != 3 then return "expected 3 ips, got "+str(ips.len)
	for ip in ips
		if not is_valid_ip(ip.trim) then return "invalid ip: "+ip
	end for
	return null
end function

