	command.enum("-p")
	res = command.enum("-a", "delta")
	err = globals._assert_contains(res, "appended")
	if err then return err
	if command.enum("-l") != "1" then return "enum append length mismatch"
	if command.enum("0") != "delta" then return "enum append failed"
	command.enum("-p")
