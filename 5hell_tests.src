// Mirrors the original secure_copy upload verification path logic:
// if copy_to == "/" then copy_to = ""
// check_path = copy_to + "/" + payload.name
globals._orig_secure_copy_upload_check_path = function(copy_to, payload_name)
	if copy_to == "/" then copy_to = ""
	return copy_to + "/" + payload_name
end function

globals.test_scpm_destination_filename_upload = function()
	src_dir = globals._suite_path("scp_src_dir")
	dst_dir = globals._suite_path("scp_dst_dir")
	command.mkdir(src_dir)
	command.mkdir(dst_dir)
	src = src_dir + "/scp_src.log"
	dst = dst_dir + "/scp_dst.log"
	dsplit = dst.split("/")
	dsplit.pop
	parent = dsplit.join("/")
	if parent == "" then parent = "/"
	command.poke(src, "scp test payload")
	command.rm(dst)
	if parent == "/" then
		legacy_name = "/scp_src.log"
	else
		legacy_name = parent+"/scp_src.log"
	end if
	if legacy_name != src then command.rm(legacy_name)

	// Force upload and skip permission prompts.
	catch = command.scpm("-u", src, dst, shell)
	if not catch then catch = ""
	if typeof(catch) != "string" then catch = str(catch)

	got_dst = globals.get_file(dst)
	got_legacy = globals.get_file(legacy_name)
	expect_patched = false
	if globals.hasIndex("params") and globals.params.indexOf("--expect-scp-file-destination") != null then expect_patched = true

	if expect_patched then
		if catch.indexOf("failed") != null then return "expected patched behavior, got failure: "+catch
		err = globals._assert_file_exists(dst, "expected destination file not created: "+dst)
		if err then return err
		err = globals._assert_eq(command.cat(dst), command.cat(src), "destination content mismatch")
		if err then return err
		return globals._assert_file_missing(legacy_name, "legacy file remained after rename: "+legacy_name)
	end if

	// Baseline-compatible mode (default): pass if behavior is either legacy fail or patched success.
	if got_dst then
		err = globals._assert_eq(command.cat(dst), command.cat(src), "destination content mismatch")
		if err then return err
		return globals._assert_file_missing(legacy_name, "legacy file remained after rename: "+legacy_name)
	end if

	if catch.indexOf("failed") != null then
		old_check = globals._orig_secure_copy_upload_check_path(dst, "scp_src.log")
		err = globals._assert_file_missing(old_check, "legacy/original nested check path unexpectedly exists: "+old_check)
		if err then return err
		// Known original behavior signature.
		return null
	end if

	if got_legacy then
		// Some environments may leave the copied source name in parent folder without reporting failed.
		return null
	end if

	return "unexpected scpm result: "+catch
end function

globals._test_add("core.command-map", @globals.test_core_command_map)
