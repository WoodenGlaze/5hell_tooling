globals._assert_function_set = function(func_names, scope_label, optional_missing=[])
	missing = []
	for fname in func_names
		found = false
		if scope_label == "command" then
			if command.hasIndex(fname) and typeof(command[fname]) == "function" then found = true
		else
			if globals.hasIndex(fname) and typeof(globals[fname]) == "function" then found = true
		end if
		if not found and optional_missing.indexOf(fname) == null then missing.push(fname)
	end for
	if missing.len > 0 then return scope_label+" missing: "+missing.join(", ")
	return null
end function

globals.PIPE_HITS = []

command.testsink = function(arg1=0, arg2=0, arg3=0, arg4=0)
	hit = ""
	if typeof(arg1) == "string" then hit = arg1
	if typeof(arg1) == "number" then hit = str(arg1)
	if typeof(arg1) == "file" then hit = arg1.path
	if typeof(arg1) == "list" then hit = arg1.join(" ")
	if hit == "" then hit = typeof(arg1)
	globals.PIPE_HITS.push(hit)
	return hit
end function

globals._suite_path = function(name)
	return globals._test_root + "/" + name
end function

globals._run_one = function(t)
	name = t["name"]
	fn = t["fn"]
	saved_path = globals.currentPath
	err = fn()
	if globals.currentPath != saved_path then command.cd(saved_path)
	if err then
		globals._test_fails = globals._test_fails + 1
		print("TEST:FAIL:"+name+":"+err)
	else
		globals._test_passes = globals._test_passes + 1
		print("TEST:PASS:"+name)
	end if
end function

globals.run_tests = function()
	globals._test_passes = 0
	globals._test_fails = 0
	for t in globals._test_cases
		globals._run_one(t)
	end for
	print("TEST:SUMMARY:pass="+globals._test_passes+" fail="+globals._test_fails)
	return globals._test_fails == 0
end function

globals._keep_artifacts = false
if globals.hasIndex("params") and globals.params.indexOf("--keep") != null then globals._keep_artifacts = true

globals._test_root = globals.homePath + "/5hell_test_suite"

globals._prep_fs = function()
	if globals.get_file(globals._test_root) then
		command.rm("-r", globals._test_root)
	end if
	command.mkdir(globals._test_root)
	if not globals.get_file(globals._test_root) then return "failed to create test directory"
	cd_err = command.cd(globals._test_root)
	if cd_err then return cd_err
	return null
end function

globals._cleanup_fs = function()
	command.cd(globals.homePath)
	command.rm("-r", globals._test_root)
end function

setup_err = globals._prep_fs()
if setup_err then
	print("TEST:FAIL:setup:"+setup_err)
	print("TEST:SUMMARY:pass=0 fail=1")
	exit("test setup failed")
end if

globals.test_core_command_map = function()
	if not command.hasIndex("echo") then return "missing command.echo"
	if not command.hasIndex("calc") then return "missing command.calc"
	if not command.hasIndex("md5") then return "missing command.md5"
	if not command.hasIndex("rnip") then return "missing command.rnip"
	if not command.hasIndex("do") then return "missing command.do"
	if not command.hasIndex("enum") then return "missing command.enum"
	return null
end function

